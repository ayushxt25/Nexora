# Real frontend API base URL for the app. Point this at the public backend
# origin in deployed environments.
VITE_BACKEND_URL=http://localhost:8000

# Auth provider mode. Keep "legacy" for local legacy-auth development, or set
# to "supabase" for deployed Supabase auth.
VITE_AUTH_PROVIDER=legacy

# Supabase browser-safe public config. Use the project's public URL and anon
# key only. Never put a service_role key in the frontend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
