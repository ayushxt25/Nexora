# Copy this file to .env and fill in real values before running in any
# shared or production-like environment. Never commit a real .env file --
# it's already excluded via .gitignore.
#
# None of these are required for local development: every one of them has
# a safe default for running on your own machine. SECRET_KEY is the only
# one you MUST change before deploying anywhere other than your own laptop.

# ---------------------------------------------------------------------------
# Backend (FastAPI)
# ---------------------------------------------------------------------------

# Secret key used to sign JWT access tokens. MUST be overridden with a long,
# random value in any real deployment -- anyone who knows this value can
# forge valid login tokens for any user.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=INSECURE-DEV-ONLY-CHANGE-ME

# How long an issued JWT access token remains valid, in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database connection string. Defaults to a local SQLite file at
# ./data/app.db if not set. For PostgreSQL use, e.g.:
#   DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/networking_assistant
# Use PostgreSQL for any deployed environment; keep SQLite only for local
# development and tests.
DATABASE_URL=sqlite:///./data/app.db
POSTGRES_DB=networking_assistant
POSTGRES_USER=networking
POSTGRES_PASSWORD=networking

# Optional background worker foundation. Leave disabled for normal local
# development unless you're also running Redis + a Celery worker.
CELERY_ENABLED=false
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
REDIS_URL=redis://localhost:6379/0

# Optional caching layer. Safe to leave disabled; the app continues to work
# normally when Redis is absent or unreachable.
CACHE_ENABLED=false
CACHE_TTL_SECONDS=300

# Comma-separated frontend origins allowed to call the backend from browsers.
# Keep this explicit in shared/production environments instead of using "*".
# For a real deployment, set this to the exact frontend origin(s), e.g.:
#   CORS_ALLOWED_ORIGINS=https://app.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase auth integration. Enable this for deployed Supabase-backed auth.
# Keep dual auth enabled only while migrating or if you intentionally want to
# preserve legacy /auth/login tokens alongside Supabase. For a cleaner
# production setup later, consider SUPABASE_DUAL_AUTH_ENABLED=false.
SUPABASE_AUTH_ENABLED=false
SUPABASE_DUAL_AUTH_ENABLED=true
SUPABASE_URL=
SUPABASE_AUDIENCE=authenticated

# Optional shared-secret verification path. Leave empty when using JWKS-only
# verification from SUPABASE_URL. Never expose a real secret in the frontend.
SUPABASE_JWT_SECRET=

# Optional admin bootstrap allow-lists. Matching is case-insensitive and
# whitespace-safe. Use exact production emails/usernames only.
ADMIN_EMAILS=
ADMIN_USERNAMES=

# Optional local ML ranker foundation. Disabled by default; recommendation
# scoring continues to use rule-based logic when off or when no model exists.
ML_RANKER_ENABLED=false
ML_RANKER_MODEL_DIR=./data/models
ML_RANKER_BLEND_WEIGHT=0.35
ML_RANKER_MIN_LABELED_ROWS=3

# ---------------------------------------------------------------------------
# Frontend (Vite/React)
# ---------------------------------------------------------------------------

# The frontend reads its own Vite env vars from frontend-react/.env or
# frontend-react/.env.example. The real app uses VITE_BACKEND_URL.
# VITE_API_BASE_URL appears only in test helpers/backward-compatible fallbacks
# and should not be treated as the primary deployment variable.
